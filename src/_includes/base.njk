<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ site.name }}</title>
    <link rel="icon" type="image/png" href="/images/favicon.png" />
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body class="bg-white text-navy font-sans">

    <!-- Header -->
    <header class="bg-white border-b border-gray-100 sticky top-0 z-50">
      <div class="max-w-6xl mx-auto px-6 py-4">
        <a href="/" aria-label="{{ site.name }}">
          <img src="/images/nordpapp-logo.png" alt="{{ site.name }}" class="h-9" />
        </a>
      </div>
    </header>

    <!-- Page sections -->
    <main>
      {{ content | safe }}
    </main>

    <!-- Footer -->
    <footer class="bg-navy py-12 px-6 text-center">
      <div class="mb-6">
        <img src="/images/nordpapp-symbol.png" alt="{{ site.name }}" class="h-14 mx-auto" />
      </div>
      <p class="text-brand-beige text-sm">{{ site.footer }}</p>
    </footer>

  </body>
</html>
