{%- set colCount = section.data.columns | length -%}

<section class="py-20 px-6 bg-white">
  <div class="max-w-6xl mx-auto">

    {# Optional section heading #}
    {% if section.data.title %}
    <h2 class="text-3xl md:text-4xl font-bold text-navy text-center mb-4">
      {{ section.data.title }}
    </h2>
    {% endif %}

    {# Optional intro text (rendered markdown body of the file) #}
    {% if section.templateContent | trim %}
    <div class="text-center text-gray-600 mb-12 max-w-2xl mx-auto
      [&_p]:text-lg [&_p]:leading-relaxed">
      {{ section.templateContent | safe }}
    </div>
    {% endif %}

    {# Column grid — stacks to 1 col on mobile #}
    <div class="grid grid-cols-1 gap-8
      {% if colCount == 2 %}md:grid-cols-2{% elif colCount >= 3 %}md:grid-cols-3{% endif %}">
      {% for col in section.data.columns %}
      <div class="p-8 rounded-lg bg-brand-beige/30 border border-brand-beige">
        <h3 class="text-xl font-bold text-navy mb-3">{{ col.title }}</h3>
        <p class="text-gray-700 leading-relaxed">{{ col.text }}</p>
      </div>
      {% endfor %}
    </div>

  </div>
</section>
