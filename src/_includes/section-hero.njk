{%- set bgImage = section.data.backgroundImage -%}

<section
  class="relative w-full min-h-[75vh] bg-navy bg-cover bg-center flex items-center justify-center"
  {% if bgImage %}style="background-image: url('{{ bgImage }}')"{% endif %}
>
  {# Overlay so text is always readable over any background image #}
  <div class="absolute inset-0 bg-navy/60"></div>

  <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto
    [&_h1]:text-5xl [&_h1]:md:text-7xl [&_h1]:font-bold [&_h1]:leading-tight [&_h1]:mb-6
    [&_h2]:text-3xl [&_h2]:md:text-5xl [&_h2]:font-semibold [&_h2]:leading-tight [&_h2]:mb-4
    [&_p]:text-xl [&_p]:md:text-2xl [&_p]:text-white/80 [&_p]:max-w-2xl [&_p]:mx-auto [&_p]:mt-4">
    {{ section.templateContent | safe }}
  </div>
</section>
