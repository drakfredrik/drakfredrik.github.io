{
  "name": "nordpapp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npx @11ty/eleventy",
    "build:css": "npx @tailwindcss/cli -i ./src/css/input.css -o ./src/css/styles.css --minify",
    "start": "concurrently \"npx @tailwindcss/cli -i ./src/css/input.css -o ./src/css/styles.css --watch\" \"npx @11ty/eleventy --serve\""
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@tailwindcss/cli": "^4.2.2",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.2.2"
  }
}
